---
import { LinkButton } from '@astrojs/starlight/components';
import logo from '../assets/glimmer_logo.png';

const { data } = Astro.locals.starlightRoute.entry;
const { tagline, actions = [] } = data.hero || {};

// 这个不是标准的 Starlight 字段，使用局部常量
const heroName = 'Glimmer'; 
---

<div class="hero">
  
  <div class="hero-image-container">
    <div class="glow-layer"></div>
    <img src={logo.src} alt="微光 Logo" class="hero-image" />
  </div>

  <div class="sl-flex stack">
    <div class="sl-flex copy">
      <span style="display: block; font-size: clamp(var(--sl-text-3xl), calc(0.25rem + 5vw), var(--sl-text-6xl)); line-height: var(--sl-line-height-headings); font-weight: 600; background: linear-gradient(135deg, #3C8CE7 10%, #00EAFF 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; color: transparent; padding-bottom: 0.1em;">
        {heroName}
      </span>
      <!-- 使用自定义的标题名称 -->
      <h1 id="_top" data-page-title set:html=2026-微光招新 />
      {tagline && <div class="tagline" set:html={tagline} />}
    </div>
    
    <div class="sl-flex actions">
      {/* 动态渲染来自 index.mdx 的按钮配置 */}
      {actions.map(({ text, link, icon, variant }) => (
        <LinkButton href={link} variant={variant} icon={icon?.name}>
          {text}
        </LinkButton>
      ))}
    </div>
  </div>

</div>

<style>
  .hero {
    display: grid;
    grid-template-columns: 100%;
    align-items: center;
    gap: 1rem;
    padding-bottom: 1rem;
  }
  
  .stack {
    flex-direction: column;
    gap: clamp(1.5rem, 1.5rem + 1vw, 2rem);
    text-align: center;
  }

  .copy {
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .copy > * {
    max-width: 50ch;
  }

  h1 {
    font-size: clamp(var(--sl-text-3xl), calc(0.25rem + 5vw), var(--sl-text-6xl));
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .tagline {
    font-size: clamp(var(--sl-text-base), calc(0.0625rem + 2vw), var(--sl-text-xl));
    color: var(--sl-color-gray-2);
  }

  .actions {
    gap: 1rem 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* --- 核心光晕容器布局 --- */
  .hero-image-container {
    width: min(70%, 20rem);
    margin-inline: auto;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1;
  }

  .hero-image {
    width: 100%;
    height: auto;
    object-fit: contain;
    position: relative; 
    z-index: 2; 
  }

  .glow-layer {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: -1;
    
    width: 90%;
    height: 90%;
    border-radius: 50%;
    
    background: linear-gradient(135deg, #43CBFF 10%, #9708CC 100%);
    filter: blur(80px);
    opacity: 0.8;
    pointer-events: none;
  }

  /* 桌面端布局适配 */
  @media (min-width: 50rem) {
    .hero {
      grid-template-columns: 7fr 4fr;
      gap: 3%;
      padding-block: clamp(2.5rem, 1rem + 10vmin, 10rem);
    }

    .hero-image-container {
      order: 2; /* 把桌面端将原本在上面的图片排到右侧 */
      width: min(100%, 25rem);
    }

    .stack {
      text-align: start;
    }

    .copy {
      align-items: flex-start;
    }

    .actions {
      justify-content: flex-start;
    }
    
    .glow-layer {
       filter: blur(120px);
    }
  }
</style>