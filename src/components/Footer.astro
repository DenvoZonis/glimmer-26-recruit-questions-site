---
import type { Props } from '@astrojs/starlight/props';
import DefaultFooter from '@astrojs/starlight/components/Footer.astro';
---

<DefaultFooter {...Astro.props} />

<div class="custom-footer">
  <p>
    <span>本站已支持IPv6访问</span>
    <span class="separator"> || </span>
    <span>Copyright &copy; 2026 glimmer</span>
    <span class="separator"> || </span>
    <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer">
      蜀ICP备2026040807号-1
    </a>
  </p>
</div>

<style>
  .custom-footer {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--sl-color-hairline);
    text-align: center;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
  }
  
  .custom-footer p {
    margin: 0;
    /* 弹性布局：让文本和链接垂直居中，并允许在手机屏幕上自动换行 */
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap; 
    gap: 0.5rem; /* 元素之间的间距 */
  }

  .separator {
    opacity: 0.5; /* 让“||”符号稍微透明一点，视觉上更精致 */
  }

  .custom-footer a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .custom-footer a:hover {
    color: var(--sl-color-text-accent);
  }
</style>